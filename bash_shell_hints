# Quick hints

# Search/history
rg <pattern> <path>              # fast search
fd <name>                        # fast find
history -a, history, !<num>      # flush/save, show, rerun by number
Ctrl-R                           # McFly history search

# Secrets (GPG/ak)
ak list                          # show configured services + status
ak get <service>                 # decrypt one secret
eval "$(ak export)"             # load all API keys into current shell
export OPENROUTER_API_KEY="$(ak get openrouter)"  # load just OpenRouter
export DEEPINFRA_API_KEY="$(ak get deepinfra)"    # load just DeepInfra
gpgconf --kill gpg-agent          # lock GPG cache immediately (default TTL: 20h)
ssh-add -l                        # list SSH identities (default TTL: 20h)

# WSL/Windows helpers
clipcopy                         # alias -> win-clipboard set
clippaste                        # alias -> win-clipboard get
snip                             # alias -> win-clipboard snip (save screenshot clipboard to /tmp)
shot                             # alias -> win-clipboard shot
screenshot                       # alias -> win-clipboard screenshot
wslpath "C:\Users\jackc\Downloads"  # Windows path -> WSL path

# tmux helpers
tmux ls                          # list tmux sessions
t                                # new isolated socketed session
tclean                           # cleanup unattached sessions
